#!/bin/sh

# Runs release tasks using `eval`, if given.
case $RELEASE_COMMAND in
    create)
        exec $SELF eval 'SM.Release.create()'
        ;;

    migrate)
        exec $SELF eval 'SM.Release.migrate()'
        ;;

    rollback)
        if [ -z "$2" ]; then
            echo "Specify a version to rollback to!"
            exit 1
        fi
        exec $SELF eval "SM.Release.rollback(SM.Repo, $2)"
        ;;
esac
