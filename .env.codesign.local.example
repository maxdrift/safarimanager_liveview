# Copy to .env.codesign.local (gitignored) and adjust paths/passwords.
#
# Quick check (no keychain): ./scripts/test_macos_codesign_setup.sh --validate-only

export MACOS_CERTIFICATE_P12="$HOME/DeveloperIDApplication.p12"
# Use single quotes if the password contains $, !, or backticks.
export MACOS_CERTIFICATE_PASSWORD='your-p12-export-password'
export KEYCHAIN_PASSWORD="random-string-for-throwaway-ci-keychain"

# Same as GitHub secret MACOS_CERTIFICATE_BASE64 (omit MACOS_CERTIFICATE_P12 if you use this):
# export MACOS_CERTIFICATE_BASE64="MII..."
