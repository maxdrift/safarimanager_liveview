<Dialog {=@id} {=@show}>
  <div class="card-title">
    {String.capitalize(Atom.to_string(@action))} {@entity_name}
  </div>
  <Form
    for={@changeset}
    change={@validate}
    submit={@submit}
    as={:entity}
    opts={autocomplete: "off"}
  >
    <div class="card-body">
      <Field name={:numeric_id} class="form-control">
        <Label class="label">
          <span class="label-text">Numeric ID</span>
        </Label>
        <NumberInput
          class={state_class("input input-bordered", @changeset, :numeric_id, [])}
          opts={phx_debounce: "1000"}
        />
        <Label class="label h-7">
          <ErrorTag />
        </Label>
      </Field>
      <Field name={:name} class="form-control">
        <Label class="label">
          <span class="label-text">Name</span>
        </Label>
        <TextInput
          class={state_class("input input-bordered", @changeset, :name, [])}
          opts={phx_debounce: "1000"}
        />
        <Label class="label h-7">
          <ErrorTag />
        </Label>
      </Field>
      <Field name={:scientific_name} class="form-control">
        <Label class="label">
          <span class="label-text">Scientific Name</span>
        </Label>
        <TextInput
          class={state_class("input input-bordered", @changeset, :scientific_name, [])}
          opts={phx_debounce: "1000"}
        />
        <Label class="label h-7">
          <ErrorTag />
        </Label>
      </Field>
      <Field name={:coefficient} class="form-control">
        <Label class="label">
          <span class="label-text">Coefficient</span>
        </Label>
        <Select
          options={@coefficients}
          selected={@entity.coefficient}
          prompt="Select a coefficient"
          class={state_class("input input-bordered", @changeset, :coefficient, [])}
          opts={phx_debounce: "1000"}
        />
        <Label class="label h-7">
          <ErrorTag />
        </Label>
      </Field>
      <Field name={:type} class="form-control">
        <Label class="label">
          <span class="label-text">Type</span>
        </Label>
        <Select
          options={@subject_types}
          prompt="Select a type"
          class={state_class("input input-bordered", @changeset, :type, [])}
          opts={phx_debounce: "1000", selected: @entity.type}
        />
        <Label class="label h-7">
          <ErrorTag />
        </Label>
      </Field>
      <HiddenInput field={:_action} value={@action} />
    </div>
    <div class="modal-action">
      <Submit
        values={[action: @action]}
        class={
          "btn btn-md",
          "btn-success": @changeset.action && @changeset.valid?,
          "btn-disabled": !(@changeset.action && @changeset.valid?)
        }
      >Save</Submit>
      <Reset click="hide" class="btn btn-md btn-ghost" value="Close" />
    </div>
  </Form>
</Dialog>
