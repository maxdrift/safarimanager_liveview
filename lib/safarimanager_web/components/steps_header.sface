<div class="pt-4 text-center hidden lg:block">
  <ul class="steps steps-horizontal">
    {#for {step, index} <- Enum.with_index(steps(@competition_id), 1)}
      <li class={"step", "step-primary": index <= @current_step}>
        <a href={step.url}>
          {step.name}
        </a>
      </li>
    {/for}
  </ul>
</div>
