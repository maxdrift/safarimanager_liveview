<div class="flex flex-col flex-nowrap h-screen" :on-window-keyup="evaluation-key">
  <div class="flex-initial">
    <div class="flex flex-row justify-between">
      <div class="btn-group">
        <span class="inline-block align-sub p-1 pl-3 font-bold">{@curr_slide && String.capitalize(@curr_slide.subject.name)}</span>
        <span class="inline-block align-sub p-1 pl-3 font-bold">{@curr_index + 1} of {@image_count}</span>
      </div>
      <div class={
        "my-auto",
        "badge",
        "badge-success": @curr_slide && @curr_slide.status == :submitted_jury,
        "badge-warning": @curr_slide && @curr_slide.status == :submitted_fixed
      }>
        {@curr_slide && status_to_label(@curr_slide.status)}
      </div>
      <div class="flex flex-row justify-between gap-2">
        <div class="btn-group">
          <JuryToolbarButton click="prev-image">Prev</JuryToolbarButton>
          <JuryToolbarButton click="next-image">Next</JuryToolbarButton>
        </div>
        <div class="btn-group">
          <JuryToolbarButton id="zoom-out">-</JuryToolbarButton>
          <JuryToolbarButton id="zoom-100">100%</JuryToolbarButton>
          <JuryToolbarButton id="home">Fit</JuryToolbarButton>
          <JuryToolbarButton id="zoom-in">+</JuryToolbarButton>
        </div>
        <JuryToolbarButton id="full-page">FS</JuryToolbarButton>
        <a href={"/organize/#{@competition.id}/validation_launcher"} class="btn btn-sm">
          Exit
        </a>
      </div>
    </div>
  </div>
  <!-- phx-update="ignore" is VERY VERY important! -->
  <div id="openseadragon-viewer" class="flex-1" :hook="Lightbox" phx-update="ignore"> </div>
  <div class="flex-initial">
    <div class="flex flex-row">
      {#if @curr_slide}
        <JuryToolbarButton
          click="flag"
          click_key="reason"
          click_value="wrong-subject"
          class={
            "btn",
            "btn-sm",
            "ml-2",
            "btn-error": @curr_slide && @curr_slide.flags && @curr_slide.flags.wrong_subject
          }
        >Wrong subject</JuryToolbarButton>
        <Form for={:wrong_subject_flag} change="validate" class="mx-2">
          <Select
            field="subject"
            options={Enum.map(@subjects, &{&1.name, &1.id})}
            selected={(@curr_slide.flags && @curr_slide.flags.wrong_subject_ctx &&
               @curr_slide.flags.wrong_subject_ctx.to) || @curr_slide.subject_id}
            class="select select-bordered select-sm text-xs w-full max-w-xs"
            opts={disabled: !(@curr_slide.flags && @curr_slide.flags.wrong_subject)}
          />
        </Form>
        <JuryToolbarButton
          click="flag"
          click_key="reason"
          click_value="other"
          class={"btn", "btn-sm", "btn-error": @curr_slide && @curr_slide.flags && @curr_slide.flags.other_reason}
        >Other reason</JuryToolbarButton>
        <Form for={:other_reason_flag} change="validate" class="mx-2 w-60">
          <TextInput
            field="reason"
            class="input input-bordered input-sm text-xs w-full max-w-xs"
            value={@curr_slide.flags && @curr_slide.flags.other_reason_ctx}
            opts={
              placeholder: "Insert a reason here...",
              disabled: !(@curr_slide.flags && @curr_slide.flags.other_reason)
            }
          />
        </Form>
      {/if}
    </div>
  </div>
</div>
