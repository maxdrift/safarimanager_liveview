<Context get={form: form, field: field}>
  <div class="flex flex-col" x-data="{ open: false }">
    <div class="dropdown">
      <!-- <TextInput
      class={@class}
      opts={phx_debounce: "1000"}
      :on-keyup="search"
      x-on:keydown="open = true"
    /> -->
      <input
        class={@class}
        id={input_id(form, field)}
        autocomplete="off"
        type="text"
        :on-keyup="search"
        x-on:keydown="open = true"
      />
      <ul
        class="dropdown-content bg-base-100 mt-2 rounded-lg border border-gray-700 shadow z-50"
        x-show="open"
        @click.away="open = false"
      >
        <li class="p-4 pb-2 italic text-sm text-gray-400 min-w-max">
          {Enum.count(@items)} Results
        </li>
        {#for item <- @items}
          <li
            class="px-4 py-2 cursor-pointer hover:bg-base-200 first:pt-4 first:rounded-t-lg last:pb-4 last:rounded-b-lg"
            :on-click="select_item"
            :values={item: item.id}
            @click.away="open = false"
          >
            {item.name}
          </li>
        {#else}
          No items.
        {/for}
      </ul>
    </div>
  </div>
</Context>
