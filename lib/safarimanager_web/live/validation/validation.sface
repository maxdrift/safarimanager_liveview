<div class="flex flex-col flex-nowrap h-screen" :on-window-keyup="evaluation-key">
  <div class="flex-initial">
    <div class="flex flex-row justify-between">
      <div class="btn-group">
        <span class="inline-block align-sub p-1 pl-3 font-bold">{@curr_index + 1} {gettext("of")} {@image_count}</span>
        <div class={
          "mt-1.5",
          "ml-4",
          "badge",
          "badge-success": @curr_slide && @curr_slide.status == :submitted_jury,
          "badge-warning": @curr_slide && @curr_slide.status == :submitted_fixed
        }>
          {@curr_slide && status_to_label(@curr_slide.status)}
        </div>
      </div>
      <div class="my-auto">
        <span class="inline-block align-sub p-1 pl-3 font-bold">{@curr_slide && String.capitalize(@curr_slide.subject.name)}</span>
      </div>
      <div class="flex flex-row justify-between gap-2">
        <div class="btn-group">
          <JuryToolbarButton click="prev-image">{gettext("Prev")}</JuryToolbarButton>
          <JuryToolbarButton click="next-image">{gettext("Next")}</JuryToolbarButton>
        </div>
        <div class="btn-group">
          <JuryToolbarButton id="zoom-out">-</JuryToolbarButton>
          <JuryToolbarButton id="zoom-100">100%</JuryToolbarButton>
          <JuryToolbarButton id="home">{gettext("Fit")}</JuryToolbarButton>
          <JuryToolbarButton id="zoom-in">+</JuryToolbarButton>
        </div>
        <JuryToolbarButton id="full-page">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"
            />
          </svg>
        </JuryToolbarButton>
        <a href={"/organize/#{@competition.id}/validation_launcher"} class="btn btn-sm">
          {gettext("Exit")}
        </a>
      </div>
    </div>
  </div>
  <!-- phx-update="ignore" is VERY VERY important! -->
  <div id="openseadragon-viewer" class="flex-1" :hook="Lightbox" phx-update="ignore" />
  <div class="flex-initial">
    <div class="flex flex-row">
      {#if @curr_slide}
        <span class="inline-block align-sub p-1 pl-3">{gettext("Wrong subject")}</span>
        <Form for={%{}} as={:wrong_subject_flag} change="validate" class="mx-2">
          <Select
            field="subject"
            options={Enum.map(@subjects, &{String.capitalize(&1.name), &1.id})}
            selected={(@curr_slide.flags && @curr_slide.flags.wrong_subject_ctx &&
               @curr_slide.flags.wrong_subject_ctx.to) || @curr_slide.subject_id}
            class="select select-bordered select-sm text-xs w-full max-w-xs"
          />
        </Form>
        <span class="inline-block align-sub p-1 pl-3">{gettext("Other reason")}</span>
        <Form for={%{}} as={:other_reason_flag} change="validate" class="mx-2 w-60">
          <TextInput
            field="reason"
            class="input input-bordered input-sm text-xs w-full max-w-xs"
            value={@curr_slide.flags && @curr_slide.flags.other_reason_ctx}
            opts={
              placeholder: gettext("Insert a reason here...")
            }
          />
        </Form>
      {/if}
    </div>
  </div>
</div>
