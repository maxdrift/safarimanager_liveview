<Layout
  current_page={~p"/organize/#{@competition.id}/validation_launcher"}
  current_user={@current_user}
>
  <CompetitionHeader {=@competition} />
  <StepsHeader current_step={5} competition_id={@competition.id} />
  <div class="mt-10 text-center">
    <Link to={"/organize/#{@competition_id}/validation"} class="btn btn-xl btn-primary">
      {gettext("Start Validation")}
    </Link>
  </div>
  <div class="mt-10">
    <table class="table table-compact table-zebra w-full text-center">
      <colgroup span="4" />
      <colgroup span="4" />
      <thead>
        <tr>
          <th scope="colgroup" colspan="4" class="bg-transparent" />
          <th scope="colgroup" colspan="4">{gettext("Checks")}</th>
        </tr>
        <tr>
          <th scope="col">{gettext("Participant #")}</th>
          <th scope="col">{gettext("Jury")}</th>
          <th scope="col">{gettext("Fixed points")}</th>
          <th scope="col">{gettext("Total")}</th>
          <th scope="col">{gettext("Submitted Count")}</th>
          <th scope="col">{gettext("Jury Count")}</th>
          <th scope="col">{gettext("Dup. Subjects")}</th>
          <th scope="col">{gettext("Flags")}</th>
        </tr>
      </thead>
      <tbody>
        {#for {participant_number, stats} <- @stats}
          <tr>
            <th>{participant_number}</th>
            <td>{stats.submitted_jury}</td>
            <td>{stats.submitted_fixed}</td>
            <td>{stats.submitted_jury + stats.submitted_fixed}</td>
            <td>
              <ValidationCheckmark variant={list_to_variant(stats.over_submitted_threshold)} />
            </td>
            <td>
              <div class="tooltip" data-tip={over_jury_th_tooltip(stats, @competition)}>
                <ValidationCheckmark variant={list_to_variant(stats.over_jury_threshold)} />
              </div>
            </td>
            <td>
              <ValidationCheckmark variant={list_to_variant(stats.duplicate_subjects)} />
            </td>
            <td>
              <ValidationCheckmark variant={list_to_variant(stats.flagged_slides)} />
            </td>
          </tr>
          <tr :if={list_to_boolean(stats.flagged_slides ++ stats.duplicate_subjects)}>
            <td />
            <td colspan="7">
              <table class="table table-compact w-full">
                <thead>
                  <tr>
                    <th class="bg-base-200">{gettext("File name")}</th>
                    <th class="bg-base-200">{gettext("Subject")}</th>
                    <th class="bg-base-200">{gettext("Status")}</th>
                    <th class="bg-base-200">{gettext("Wrong subject")}</th>
                    <th class="bg-base-200">{gettext("Other reason")}</th>
                    <th class="bg-base-200" />
                  </tr>
                </thead>
                <tbody>
                  {#for slide <- stats.flagged_slides}
                    <tr>
                      <td>{slide.file_name}</td>
                      <td><span class="capitalize">{slide.subject.name}</span></td>
                      <td>
                        <div class={
                          "my-auto",
                          "badge",
                          "badge-success": slide.status == :submitted_jury,
                          "badge-warning": slide.status == :submitted_fixed
                        }>
                          {status_to_label(slide.status)}
                        </div>
                      </td>
                      <td class="capitalize">{(slide.flags.wrong_subject_ctx &&
                           "#{subject_name(@subjects, slide.flags.wrong_subject_ctx.from)} → #{subject_name(@subjects, slide.flags.wrong_subject_ctx.to)}") ||
                          "-"}
                        <button
                          :if={slide.flags.wrong_subject}
                          :on-click="apply-subject"
                          :values={slide_id: slide.id, new_subject: slide.flags.wrong_subject_ctx.to}
                          class="btn btn-xs btn-primary ml-2"
                        >
                          {gettext("Apply")}
                        </button>
                      </td>
                      <td>{slide.flags.other_reason_ctx || "-"}</td>
                      <td>
                        <Link to={"/organize/#{@competition_id}/validation?slide_id=#{slide.id}"} class="btn btn-xs">
                          {gettext("Open")}
                        </Link>
                      </td>
                    </tr>
                  {/for}
                  {#for {slide, count} <- stats.duplicate_subjects}
                    <tr>
                      <td>-</td>
                      <td><span class="capitalize">{slide.subject.name}</span></td>
                      <td>
                        <div class={
                          "my-auto",
                          "badge",
                          "badge-success": slide.status == :submitted_jury,
                          "badge-warning": slide.status == :submitted_fixed
                        }>
                          {status_to_label(slide.status)}
                        </div>
                      </td>
                      <td>
                        {gettext("Duplicate")}: {count} {ngettext("occurrence", "occurrences", count)}
                      </td>
                      <td>-</td>
                      <td>
                        <Link to={"/organize/#{@competition_id}/validation?slide_id=#{slide.id}"} class="btn btn-xs">
                          {gettext("Open")}
                        </Link>
                      </td>
                    </tr>
                  {/for}
                </tbody>
              </table>
            </td>
          </tr>
        {#else}
          <tr>
            <td>{gettext("There are no slides yet")}</td>
            <td />
            <td />
            <td />
            <td />
            <td />
            <td />
            <td />
          </tr>
        {/for}
      </tbody>
    </table>
  </div>
  <div class="flex flex-row my-10 w-full">
    <LiveRedirect to={"/organize/#{@competition_id}/slide_selection"} class="flex-none btn gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      {gettext("Selection")}
    </LiveRedirect>
    <div class="grow" />
    <LiveRedirect
      to={"/organize/#{@competition_id}/jury_launcher"}
      class="flex-none btn btn-primary gap-2"
    >
      {gettext("Jury")}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </LiveRedirect>
  </div>
</Layout>
