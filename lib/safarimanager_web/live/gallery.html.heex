<!-- GPhotos grid clone using just CSS -->
<!-- https://github.com/xieranmaya/blog/issues/6 -->
<section class="photo-grid-section">
  <.thumbnail
    :for={{url, width, height} <- generate_random_images(50)}
    url={url}
    width={width}
    height={height}
    click="open-image"
  />
</section>
