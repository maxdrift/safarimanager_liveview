<Layout current_page={~p"/admin/subjects"} current_user={@current_user}>
  {!-- Show dialog --}
  <div
    :if={@live_action == :show}
    id="show-dialog"
    class="modal modal-open"
    :on-window-keydown={JS.patch("/admin/subjects")}
    phx-key="Escape"
  >
    <div class="modal-box">
      <div class="card-title">
        {gettext("Subject details")}
      </div>
      <div class="card-body">
        <FieldsList>
          <FieldsListItem label={gettext("Number")}>
            {@record.numeric_id}
          </FieldsListItem>
          <FieldsListItem label={gettext("Name")}>
            {@record.name}
          </FieldsListItem>
          <FieldsListItem label={gettext("Scientific Name")}>
            {@record.scientific_name}
          </FieldsListItem>
          <FieldsListItem label={gettext("Coefficient")}>
            {@record.coefficient}
          </FieldsListItem>
          <FieldsListItem label={gettext("Type")}>
            {@record.type}
          </FieldsListItem>
          <FieldsListItem label={gettext("Inserted")}>
            <DateTimeString value={@record.inserted_at} />
          </FieldsListItem>
          <FieldsListItem label={gettext("Updated")}>
            <DateTimeString value={@record.updated_at} />
          </FieldsListItem>
        </FieldsList>
      </div>
      <div class="modal-action">
        <button :on-click={JS.patch("/admin/subjects")} class="btn btn-md btn-ghost">
          {gettext("Close")}
        </button>
      </div>
    </div>
  </div>
  {!-- New-edit dialog --}
  <div
    :if={@live_action in [:new, :edit]}
    id="edit-dialog"
    class="modal modal-open"
    :on-window-keydown={JS.patch("/admin/subjects")}
    phx-key="Escape"
  >
    <div class="modal-box">
      <div class="card-title">
        <span :if={@live_action == :new}>{gettext("New subject")}</span>
        <span :if={@live_action == :edit}>{gettext("Edit subject")}</span>
      </div>
      <Form for={@changeset} change="validate" submit="submit" as={:entity} opts={autocomplete: "off"}>
        <div class="card-body">
          <SMField name={:numeric_id} label={gettext("Numeric ID")}>
            <NumberInput class={input_state_class(@changeset, :numeric_id)} opts={phx_debounce: "1000"} />
          </SMField>
          <SMField name={:name} label={gettext("Name")}>
            <TextInput class={input_state_class(@changeset, :name)} opts={phx_debounce: "1000"} />
          </SMField>
          <SMField name={:scientific_name} label={gettext("Scientific Name")}>
            <TextInput class={input_state_class(@changeset, :scientific_name)} opts={phx_debounce: "1000"} />
          </SMField>
          <SMField name={:coefficient} label={gettext("Coefficient")}>
            <Select
              options={@coefficients}
              selected={@record.coefficient}
              prompt={gettext("Select a coefficient")}
              class={input_state_class(@changeset, :coefficient)}
              opts={phx_debounce: "1000"}
            />
          </SMField>
          <SMField name={:type} label={gettext("Type")}>
            <Select
              options={@subject_types}
              selected={@record.type}
              prompt={gettext("Select a type...")}
              class={input_state_class(@changeset, :type)}
              opts={phx_debounce: "1000"}
            />
          </SMField>
          <HiddenInput field={:_action} value={@action} />
        </div>
        <div class="modal-action">
          <Submit values={[action: @action]} class={submit_state_class(@changeset)}>
            {gettext("Save")}
          </Submit>
          <Reset
            click={JS.patch("/admin/subjects")}
            class="btn btn-md btn-ghost"
            value={gettext("Cancel")}
          />
        </div>
      </Form>
    </div>
  </div>
  {!-- Index table --}
  <Grid
    id="subjects-list"
    items={item <- @streams.items}
    create_path={~p"/admin/subjects/new"}
    export_path={~p"/export?entity=subjects"}
    infinite_scroll="true"
  >
    <Column title={gettext("Num.")} class="w-1/12">
      {item.numeric_id}
    </Column>
    <Column title={gettext("Name")}>
      <div class="capitalize">{item.name}</div>
      <div class="text-sm italic capitalize opacity-50">{item.scientific_name}</div>
    </Column>
    <Column title={gettext("Coeff.")} class="w-1/12">
      {item.coefficient}
    </Column>
    <Column title={gettext("Type")} class="w-1/12">
      {item.type}
    </Column>
    <Column title={gettext("Created")} class="w-2/12">
      <DateTimeString value={item.inserted_at} />
    </Column>
    <Column title={gettext("Modified")} class="w-2/12">
      <DateTimeString value={item.updated_at} />
    </Column>
    <Column title={gettext("Actions")} class="w-4">
      <div class="overflow-x-auto">
        <LivePatch
          to={~p"/admin/subjects/#{item.id}"}
          class="btn btn-square btn-sm btn-info"
          opts={title: gettext("Show")}
        ><Heroicons.Surface.Icon name="eye" type="outline" class="w-4 h-4" /></LivePatch>
        <LivePatch
          to={~p"/admin/subjects/#{item.id}/edit"}
          class="btn btn-square btn-sm btn-warning"
          opts={title: gettext("Edit")}
        ><Heroicons.Surface.Icon name="pencil-square" type="solid" class="w-4 h-4" /></LivePatch>
        <button
          class="btn btn-square btn-sm btn-error"
          :on-click={"delete-one", target: "#subjects-list"}
          :values={id: item.id}
          title={gettext("Delete")}
        ><Heroicons.Surface.Icon name="trash" type="outline" class="w-4 h-4" /></button>
      </div>
    </Column>
  </Grid>
</Layout>
