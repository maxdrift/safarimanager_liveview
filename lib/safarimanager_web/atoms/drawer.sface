<div class="rounded-2xl shadow bg-base-200 drawer drawer-mobile h-full">
  <input id="sm-drawer" type="checkbox" class="drawer-toggle">
  <div class="flex flex-col px-4 drawer-content h-max">
    <#slot />
  </div>
  <div class="drawer-side">
    <label for="sm-drawer" class="drawer-overlay" />
    <#slot name="menu" />
  </div>
</div>
