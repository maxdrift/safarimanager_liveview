<div
  id={@url}
  class="photo-grid-div"
  style={"width:#{@width * 200 / @height}px;grow:#{@width * 200 / @height}"}
>
  <LiveRedirect
    to="/jury_viewer"
    class="photo-grid-i"
    opts={[style: "padding-bottom:#{@height / @width * 100}%"]}
  >
    <img class="photo-grid-img" src={@url} alt="">
  </LiveRedirect>
</div>
